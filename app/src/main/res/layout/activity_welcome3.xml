<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_orange">

    <!-- 1. منطقة الصورة -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topSection3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.55"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="300dp"
            android:layout_height="500dp"
            android:scaleType="fitCenter"
            android:src="@drawable/chat"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 2. منطقة النصوص المنحنية -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/white_curved_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topSection3">

        <TextView
            android:id="@+id/title3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:text="Connect with Caring Pet Owners Around You"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/desc3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:paddingHorizontal="32dp"
            android:text="Easily connect with pet owners, ask about animals, and make informed decisions."
            android:textColor="@color/text_gray"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@+id/title3" />

        <!-- النقاط (النقطة الثالثة مفعّلة) -->
        <LinearLayout
            android:id="@+id/dotsLayout3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/desc3">
            <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/dot_inactive" android:layout_marginEnd="8dp" />
            <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/dot_inactive" android:layout_marginEnd="8dp" />
            <View android:layout_width="30dp" android:layout_height="10dp" android:background="@drawable/dot_active" />
        </LinearLayout>

        <!-- زر البداية (في الصفحة الأخيرة عادة يظهر زر واحد كبير) -->
        <Button
            android:id="@+id/btnGetStarted"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="32dp"
            android:backgroundTint="@color/primary_orange"
            android:text="Let's Get Started"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="30dp"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>