<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="@drawable/rounded_background"
    android:layout_marginBottom="8dp">

    <!-- 1. صورة الحيوان -->
    <ImageView
        android:id="@+id/imgPet"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop"
        android:background="@drawable/circle_bg"
        android:padding="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 2. اسم الحيوان -->
    <TextView
        android:id="@+id/txtPetName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Pet Name"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/imgPet"
        app:layout_constraintTop_toTopOf="@+id/imgPet" />

    <!-- 3. التقييم (نجمات) -->
    <RatingBar
        android:id="@+id/petRating"
        style="?android:attr/ratingBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="0.5"
        android:progressTint="@color/primary_orange"
        app:layout_constraintStart_toStartOf="@+id/txtPetName"
        app:layout_constraintTop_toBottomOf="@+id/txtPetName"
        android:layout_marginTop="4dp"/>

    <!-- 4. السعر -->
    <TextView
        android:id="@+id/txtPetPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$100"
        android:textColor="@color/primary_orange"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/imgPet"
        app:layout_constraintStart_toStartOf="@+id/txtPetName" />

    <!-- 5. أزرار الأكشن (التفاوض والاتفاق) كما ذكر في المحاضرة -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btnDeal"
            android:layout_width="70dp"
            android:layout_height="40dp"
            android:text="Deal"
            android:textSize="10sp"
            android:backgroundTint="@color/primary_orange"
            android:textColor="@color/white"
            android:textAllCaps="false"
            app:cornerRadius="20dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>